{
  "name": "monadforge-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AI-native developer toolkit for Monad",
  "workspaces": [
    "mcp",
    "skills",
    "templates",
    "knowledge",
    "audit",
    "actions",
    "cli",
    "sdk",
    "intent",
    "plan",
    "runtime",
    "repair",
    "memory",
    "composition",
    "agent-runtime",
    "review",
    "benchmarks",
    "monadforge"
