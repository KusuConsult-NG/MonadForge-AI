{
  "$ref": "#/definitions/plan",
  "definitions": {
    "plan": {
      "type": "object",
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "number"
              },
              "description": {
                "type": "string"
              },
              "skillName": {
                "type": "string",
                "enum": [
                  "generate_contract",
                  "run_audit",
                  "deploy_contract",
                  "verify_contract",
                  "search_docs",
                  "execute_action"
                ]
              },
              "params": {
                "type": "object",
                "additionalProperties": {}
              },
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "in_progress",
                  "completed",
                  "failed",
                  "success"
                ]
              }
            },
            "required": [
              "id",
              "description",
              "skillName",
              "params",
              "status"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "steps"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}